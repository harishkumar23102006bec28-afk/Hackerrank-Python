/*
 * Complete the 'hourglassSum' function below.
 *
 * The function is expected to return an INTEGER.
 * The function accepts 2D_INTEGER_ARRAY arr as parameter.
 */

int hourglassSum(vector<vector<int>> arr) {
    // Initialize max_sum to a very small number, the minimum possible sum of an hourglass.
    // The problem constraints indicate values are between -9 and 9. The smallest possible
    // sum is 7 * -9 = -63. We can use numeric_limits for robustness.
    int max_sum = numeric_limits<int>::min();

    // The 6x6 array has 4 possible top-left corners for a 3x3 hourglass
    // in both the row (i) and column (j) directions.
    for (int i = 0; i <= 3; ++i) {
        for (int j = 0; j <= 3; ++j) {
            // Calculate the sum of the current hourglass
            int current_sum = arr[i][j] + arr[i][j+1] + arr[i][j+2]  // Top row
                                        + arr[i+1][j+1]              // Middle element
                            + arr[i+2][j] + arr[i+2][j+1] + arr[i+2][j+2]; // Bottom row

            // Update the maximum sum if the current sum is greater
            if (current_sum > max_sum) {
                max_sum = current_sum;
            }
        }
    }

    return max_sum;
}

